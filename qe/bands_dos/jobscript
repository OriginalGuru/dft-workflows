#!/bin/bash
#SBATCH -J qe_bands_dos
#SBATCH -p development
#SBATCH -N 1
#SBATCH -n 32
#SBATCH -A PHY24018
#SBATCH -o slurm-%j.log
#SBATCH -e slurm-%j.log
#SBATCH -t 00:30:00

# --- Paths ---
WORKDIR=$SLURM_SUBMIT_DIR
RUNDIR=$SCRATCH/qe_runs/${SLURM_JOB_ID}

mkdir -p $RUNDIR
cd $RUNDIR

# --- Stage inputs ---
cp $WORKDIR/scf.in .
cp $WORKDIR/nscf_bands.in .
cp $WORKDIR/bands.in .
cp $WORKDIR/nscf_dos.in .
cp $WORKDIR/dos.in .

# --- Modules ---
module purge
module load intel/19.1.1 impi/19.0.9
module load qe/7.3
module list

# --- Run ---
JOB_START=$(date +%s)
echo "Job started at $(date) on $(hostname)"

export OMP_NUM_THREADS=1

# --- Step 1: SCF (pw.x) ---
echo "Starting SCF (pw.x) at $(date)"
T0=$(date +%s)
ibrun pw.x -input scf.in > scf.out
T1=$(date +%s); DT=$((T1-T0))
printf "SCF done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 2: nscf along band path (pw.x) ---
echo "Starting nscf bands (pw.x) at $(date)"
T0=$(date +%s)
ibrun pw.x -input nscf_bands.in > nscf_bands.out
T1=$(date +%s); DT=$((T1-T0))
printf "nscf bands done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 3: bands.x (extract bands for plotting) ---
echo "Starting bands.x at $(date)"
T0=$(date +%s)
ibrun bands.x -input bands.in > bands.out
T1=$(date +%s); DT=$((T1-T0))
printf "bands.x done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 4: nscf on 8x8x8 mesh for DOS (pw.x) ---
echo "Starting nscf dos (pw.x) at $(date)"
T0=$(date +%s)
ibrun pw.x -input nscf_dos.in > nscf_dos.out
T1=$(date +%s); DT=$((T1-T0))
printf "nscf dos done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 5: dos.x (integrate DOS) ---
echo "Starting dos.x at $(date)"
T0=$(date +%s)
ibrun dos.x -input dos.in > dos.out
T1=$(date +%s); DT=$((T1-T0))
printf "dos.x done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Stage outputs back to $WORKDIR ---
mkdir -p $WORKDIR/results_${SLURM_JOB_ID}
rsync -a --exclude 'outdir/*.save/' --exclude '*wfc*.dat' $RUNDIR/ $WORKDIR/results_${SLURM_JOB_ID}/

JOB_END=$(date +%s)
ELAPSED=$(( JOB_END - JOB_START ))
echo "Job finished at $(date)"
printf "Total wall time: %d-%02d:%02d:%02d\n" \
    $(( ELAPSED/86400 )) $(( (ELAPSED%86400)/3600 )) $(( (ELAPSED%3600)/60 )) $(( ELAPSED%60 ))
