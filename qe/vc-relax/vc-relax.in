&control
 calculation  = 'vc-relax',
 restart_mode = 'from_scratch',
 pseudo_dir   = '/work/XXXX/YOUR_USERNAME/ls6/qe/pseudos/pslibrary',
 outdir       = './outdir/',
 prefix       = 'SrTiO3',
 tprnfor      = .true.,
 tstress      = .true.,
 forc_conv_thr = 1.0d-4,
 etot_conv_thr = 1.0d-5,
 nstep        = 100,
/
&system
 ibrav     = 0,
 nat       = 5,
 ntyp      = 3,
 ecutwfc   = 60,
 ecutrho   = 600,
/
&electrons
 diagonalization = 'david',
 conv_thr        = 1.0e-10,
 mixing_beta     = 0.2,
/
&ions
 ion_dynamics = 'bfgs',
/
&cell
 cell_dynamics  = 'bfgs',
 press          = 0.0,
 press_conv_thr = 0.1,
 cell_dofree    = 'all',
/
ATOMIC_SPECIES
Sr 87.620 Sr.pbesol-spn-kjpaw_psl.1.0.0.UPF
Ti 47.867 Ti.pbesol-spn-kjpaw_psl.1.0.0.UPF
O  15.999 O.pbesol-n-kjpaw_psl.1.0.0.UPF

K_POINTS automatic
4 4 4  0 0 0

CELL_PARAMETERS (angstrom)
   3.905000000   0.000000000   0.000000000
   0.000000000   3.905000000   0.000000000
   0.000000000   0.000000000   3.905000000

ATOMIC_POSITIONS (crystal)
Sr       0.500000000   0.500000000   0.500000000
Ti       0.000000000   0.000000000   0.000000000
O        0.500000000   0.000000000   0.000000000
O        0.000000000   0.500000000   0.000000000
O        0.000000000   0.000000000   0.500000000

