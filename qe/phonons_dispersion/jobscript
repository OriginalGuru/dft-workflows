#!/bin/bash
#SBATCH -J qe_ph_disp
#SBATCH -p development
#SBATCH -N 1
#SBATCH -n 32
#SBATCH -A PHY24018
#SBATCH -o slurm-%j.log
#SBATCH -e slurm-%j.log
#SBATCH -t 02:00:00

# --- Paths ---
WORKDIR=$SLURM_SUBMIT_DIR
RUNDIR=$SCRATCH/qe_runs/${SLURM_JOB_ID}

mkdir -p $RUNDIR
cd $RUNDIR

# --- Stage inputs ---
cp $WORKDIR/scf.in .
cp $WORKDIR/ph.in .
cp $WORKDIR/q2r.in .
cp $WORKDIR/matdyn.in .

# --- Modules ---
module purge
module load intel/19.1.1 impi/19.0.9
module load qe/7.3
module list

# --- Run ---
JOB_START=$(date +%s)
echo "Job started at $(date) on $(hostname)"

export OMP_NUM_THREADS=1

# --- Step 1: SCF (pw.x) ---
echo "Starting SCF (pw.x) at $(date)"
T0=$(date +%s)
ibrun pw.x -input scf.in > scf.out
T1=$(date +%s); DT=$((T1-T0))
printf "SCF done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 2: Phonons on q-mesh (ph.x) ---
echo "Starting ph.x at $(date)"
T0=$(date +%s)
ibrun ph.x -input ph.in > ph.out
T1=$(date +%s); DT=$((T1-T0))
printf "ph.x done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 3: Fourier interpolation to real space (q2r.x) ---
echo "Starting q2r.x at $(date)"
T0=$(date +%s)
q2r.x < q2r.in > q2r.out
T1=$(date +%s); DT=$((T1-T0))
printf "q2r.x done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Step 4: Interpolate frequencies along high-symmetry path (matdyn.x) ---
echo "Starting matdyn.x at $(date)"
T0=$(date +%s)
matdyn.x < matdyn.in > matdyn.out
T1=$(date +%s); DT=$((T1-T0))
printf "matdyn.x done at %s — elapsed %02d:%02d:%02d\n" "$(date)" $((DT/3600)) $(((DT%3600)/60)) $((DT%60))

# --- Stage outputs back to $WORKDIR ---
mkdir -p $WORKDIR/results_${SLURM_JOB_ID}
rsync -a --exclude 'outdir/*.save/' --exclude 'wfc*.dat' $RUNDIR/ $WORKDIR/results_${SLURM_JOB_ID}/

JOB_END=$(date +%s)
ELAPSED=$(( JOB_END - JOB_START ))
echo "Job finished at $(date)"
printf "Total wall time: %d-%02d:%02d:%02d\n" \
    $(( ELAPSED/86400 )) $(( (ELAPSED%86400)/3600 )) $(( (ELAPSED%3600)/60 )) $(( ELAPSED%60 ))

